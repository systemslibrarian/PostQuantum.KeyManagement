<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>PostQuantum.KeyManagement</RootNamespace>
    <AssemblyName>PostQuantum.KeyManagement</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible>true</IsAotCompatible>
    <NeutralLanguage>en-US</NeutralLanguage>
    <EnablePackageValidation>true</EnablePackageValidation>
  </PropertyGroup>

  <!-- ───────────────────────── NuGet package metadata ───────────────────────── -->
  <PropertyGroup>
    <PackageId>PostQuantum.KeyManagement</PackageId>
    <Version>0.4.0-preview.1</Version>
    <Authors>Paul Clark</Authors>
    <Company>Systems Librarian</Company>
    <Product>PostQuantum.KeyManagement</Product>
    <Title>PostQuantum.KeyManagement — envelope encryption + key rotation for .NET</Title>
    <Description>Clean, high-level key management and rotation for post-quantum-ready encryption in .NET. Implements the envelope-encryption pattern (256-bit content keys wrapped by a key-encryption key) with a secure local KEK provider backed by Argon2id + AES-256-GCM, full thread-safety, hostile-input-resistant token parsers, an HMAC-SHA256 keyring verifier for early passphrase detection, and a tiny extension point so cloud KMS providers (Azure Key Vault, AWS KMS, Google Cloud KMS, PKCS#11/HSMs) plug in without disturbing application code. The natural companion to PostQuantum.FileEncryption and PostQuantum.Jwt. See KNOWN-GAPS.md and docs/threat-model.md for honest, explicit limits.</Description>
    <PackageTags>post-quantum;pqc;cryptography;key-management;key-rotation;kms;argon2id;envelope-encryption;aes-gcm;security;dek;kek;hsm</PackageTags>
    <PackageProjectUrl>https://github.com/systemslibrarian/PostQuantum.KeyManagement</PackageProjectUrl>
    <RepositoryUrl>https://github.com/systemslibrarian/PostQuantum.KeyManagement</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Copyright>Copyright (c) Paul Clark</Copyright>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReleaseNotes>0.4.0-preview.1: Production-shaped preview. Adds the sibling PostQuantum.KeyManagement.Extensions.DependencyInjection package (one-line AddPostQuantumKeyManagement, an IKeyringStore abstraction with an atomic FileKeyringStore, and KeyManagementHealthCheck). Adds three end-to-end samples (Minimal API, Worker Service with scheduled rotation, EF Core with per-row envelope encryption that survives KEK rotation). Adds TryDecode overloads on WrappedContentKey and LocalKeyringMetadata for untrusted input. Adds boundary validation rejecting empty passphrases with a clear ArgumentException before any cryptographic work. Adds docs/threat-model.md (ten numbered security invariants), docs/versioning.md (SemVer and wire-format policy), and docs/deployment.md (production operational checklist). Multi-targets net8.0/net9.0/net10.0 with deterministic builds and SourceLink. Full release notes in CHANGELOG.md; the path to cloud KMS providers, external review, and 1.0 is in future.md.</PackageReleaseNotes>
  </PropertyGroup>

  <!-- ───────────────────────────── SourceLink / symbols ─────────────────────── -->
  <PropertyGroup>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" Version="1.3.1" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

</Project>
